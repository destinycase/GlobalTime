{
    "manifest_version": 3,
    "name": "Global Time Viewer",
    "version": "3.2.3",
    "description": "세계 시간 비교 / 계산 도구.",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_title": "Global Time Viewer를 새 탭에서 열기"
    },
    "permissions": [
        "downloads"
    ],
    "background": {
        "service_worker": "background.js"
    }
}
