{
    "manifest_version": 3,
    "name": "Global Time Viewer",
    "version": "3.0.0",
    "description": "세련된 다크 모드의 실시간 세계 시간 비교 도구.",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_title": "Global Time Viewer를 새 탭에서 열기"
    },
    "background": {
        "service_worker": "background.js"
    },
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "<all_urls>"
    ]
}